# LLM Configuration (OpenAI-compatible endpoint)
# Gemini via OpenRouter (default):
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key
LLM_MODEL=google/gemini-3-flash-preview
LLM_TIMEOUT=120
LLM_STRICT_VALIDATION=true
AUTO_APPROVE_GENERATED_ALT_TEXT=true

# Optional: Gemini direct OpenAI-compatible endpoint:
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=your_google_ai_studio_api_key
# LLM_MODEL=gemini-2.5-flash

# veraPDF
VERAPDF_PATH=verapdf
VERAPDF_FLAVOUR=ua1

# OCR
OCR_LANGUAGE=eng

# Debug mode
DEBUG=false
