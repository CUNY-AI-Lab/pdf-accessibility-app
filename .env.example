# LLM — any OpenAI-compatible API
# Used for alt text generation and font-mapping assistance
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=google/gemini-3-flash-preview

# Set to false for local LLM endpoints (Ollama, etc.)
# LLM_STRICT_VALIDATION=false

# OCR language (Tesseract language code)
# OCR_LANGUAGE=eng

# External binary overrides (use absolute paths or command names)
# GHOSTSCRIPT_PATH=gs
# TESSERACT_PATH=tesseract
# PDFTOPPM_PATH=pdftoppm
# BINARY_SEARCH_DIRS=/usr/bin,/usr/local/bin

# veraPDF path (if not on PATH)
# VERAPDF_PATH=verapdf

# Job TTL in hours (default: 12)
# JOB_TTL_HOURS=12

# Anonymous browser session cookie settings
# ANONYMOUS_SESSION_COOKIE_NAME=anon_session
# ANONYMOUS_SESSION_COOKIE_MAX_AGE_HOURS=720
# ANONYMOUS_SESSION_COOKIE_SECURE=false

# Browser origins allowed to call the backend directly when needed
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Published app port for docker compose (default: 8080)
# APP_PORT=8080

# Frontend base path for subpath deployments (for example /pdf-accessibility/)
# This is a build-time setting for Docker and requires rebuilding the image.
# VITE_APP_BASE_PATH=/

# Max upload size in bytes (default: 500 MB)
# MAX_UPLOAD_SIZE_BYTES=524288000

# RunPod serverless — offload Docling structure extraction to GPU
# When set, Docling runs on RunPod instead of locally.
# RUNPOD_ENDPOINT_ID=your-endpoint-id
# RUNPOD_API_KEY=your-runpod-api-key
# RUNPOD_TIMEOUT=300

# Subprocess timeouts in seconds
# SUBPROCESS_TIMEOUT_OCR=900
# SUBPROCESS_TIMEOUT_GHOSTSCRIPT=120
# SUBPROCESS_TIMEOUT_VALIDATION=600
