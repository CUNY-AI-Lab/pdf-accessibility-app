# LLM — any OpenAI-compatible API
# Used for alt text generation and font-mapping assistance
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=google/gemini-3-flash-preview

# Set to false for local LLM endpoints (Ollama, etc.)
# LLM_STRICT_VALIDATION=false

# OCR language (Tesseract language code)
# OCR_LANGUAGE=eng

# External binary overrides (use absolute paths or command names)
# GHOSTSCRIPT_PATH=gs
# TESSERACT_PATH=tesseract
# PDFTOPPM_PATH=pdftoppm
# BINARY_SEARCH_DIRS=/usr/bin,/usr/local/bin

# veraPDF path (if not on PATH)
# VERAPDF_PATH=verapdf

# Job TTL in hours (default: 24)
# JOB_TTL_HOURS=24

# Max upload size in bytes (default: 500 MB)
# MAX_UPLOAD_SIZE_BYTES=524288000

# Subprocess timeouts in seconds
# SUBPROCESS_TIMEOUT_OCR=900
# SUBPROCESS_TIMEOUT_GHOSTSCRIPT=120
# SUBPROCESS_TIMEOUT_VALIDATION=600
