# Gemini Developer API
# GEMINI_API_KEY is used for the direct PDF-understanding path and can also
# back the chat-completions fallback when LLM_API_KEY is unset.
GEMINI_API_KEY=your-gemini-api-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=google/gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview
USE_DIRECT_GEMINI_PDF=true
GEMINI_DIRECT_THINKING_LEVEL=low
GEMINI_DIRECT_ALT_TEXT_THINKING_LEVEL=medium
ALT_TEXT_MAX_CONCURRENCY=2

# Set to false for local LLM endpoints (Ollama, etc.)
# LLM_STRICT_VALIDATION=false

# OCR default language (Tesseract code). Per-job auto-detection overrides this.
# Supported: eng, spa, fra, deu, chi_sim, chi_tra, rus, ara, kor, ben, pol,
#            heb, yid, hat, hin, ita, por, jpn (and any installed Tesseract pack)
# Use + for multi-language: eng+spa
# OCR_LANGUAGE=eng

# External binary overrides (use absolute paths or command names)
# GHOSTSCRIPT_PATH=gs
# TESSERACT_PATH=tesseract
# PDFTOPPM_PATH=pdftoppm
# BINARY_SEARCH_DIRS=/usr/bin,/usr/local/bin

# veraPDF path (if not on PATH)
# VERAPDF_PATH=verapdf

# Job TTL in hours (default: 12)
# JOB_TTL_HOURS=12

# Anonymous browser session cookie settings
# ANONYMOUS_SESSION_COOKIE_NAME=anon_session
# ANONYMOUS_SESSION_CSRF_COOKIE_NAME=anon_session_csrf
# ANONYMOUS_SESSION_COOKIE_MAX_AGE_HOURS=720
# ANONYMOUS_SESSION_COOKIE_SECURE=false
# CSRF_PROTECTION_ENABLED=true

# Browser origins allowed to call the backend directly when needed
# Production subpath example: https://tools.ailab.gc.cuny.edu
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Published app port for docker compose (default: 8080)
# APP_PORT=8080

# Frontend base path for subpath deployments (for example /pdf-accessibility/)
# This is a build-time setting for Docker and requires rebuilding the image.
# VITE_APP_BASE_PATH=/

# Include local Docling in Docker image builds.
# Leave false when DOCLING_SERVE_URL points to a remote docling-serve instance.
# WITH_LOCAL_DOCLING=false

# Max upload size in bytes (default: 500 MB)
# MAX_UPLOAD_SIZE_BYTES=524288000
# MAX_FILES_PER_UPLOAD=5
# MAX_ACTIVE_JOBS_PER_SESSION=3
# MAX_ACTIVE_JOBS_GLOBAL=12
# MAX_CONCURRENT_JOBS=2

# Docling-serve URL for structure extraction (optional)
# Falls back to local Docling if not set.
# On Apple Silicon, a local docling-serve can be started with DOCLING_DEVICE=mps.
# DOCLING_SERVE_URL=http://localhost:5001
# DOCLING_SERVE_TOKEN=replace-with-docling-bearer-token
# DOCLING_SERVE_OCR_ENGINE=rapidocr

# Subprocess timeouts in seconds
# SUBPROCESS_TIMEOUT_OCR=900
# SUBPROCESS_TIMEOUT_GHOSTSCRIPT=120
# SUBPROCESS_TIMEOUT_VALIDATION=600
