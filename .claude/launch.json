{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "app.main:app", "--reload", "--port", "8001"],
      "port": 8001,
      "cwd": "backend"
    },
    {
      "name": "frontend",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev", "--port", "5180", "--strictPort"],
      "port": 5180,
      "cwd": "frontend"
    }
  ]
}
